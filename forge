#!/usr/bin/env bash
# forge - the ps2-forge command line. Make PS2 games without memorizing make.
#
#   ./forge doctor          check your toolchain is ready
#   ./forge new <name>      scaffold a new game in ./<name>
#   ./forge build           compile the game in the current folder -> .elf
#   ./forge run             build + boot it in the Play! emulator
#   ./forge test            build + boot headless + print RENDER: PASS/FAIL
#   ./forge shot            build + boot headless + save shot.png
#   ./forge list            list the bundled examples
#   ./forge play <example>  build + run a bundled example (e.g. forge play spin3d)
#   ./forge gui             open a local web dashboard to browse + preview games
#
# Run this where the ps2dev toolchain lives (PS2DEV/PS2SDK/GSKIT on PATH).
set -euo pipefail
FORGE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

c_g(){ printf '\033[32m%s\033[0m\n' "$*"; }
c_r(){ printf '\033[31m%s\033[0m\n' "$*"; }
c_y(){ printf '\033[33m%s\033[0m\n' "$*"; }

# print the contiguous leading comment block (after the shebang) as help
usage(){ awk 'NR>1{ if(/^#/){sub(/^# ?/,"");print} else exit }' "${BASH_SOURCE[0]}"; }

have(){ command -v "$1" >/dev/null 2>&1; }

doctor(){
    local ok=1
    echo "ps2-forge doctor"
    echo "----------------"
    for v in PS2DEV PS2SDK GSKIT; do
        if [ -n "${!v:-}" ] && [ -d "${!v}" ]; then c_g "  OK   \$$v = ${!v}"
        else c_r "  MISS \$$v not set or folder missing"; ok=0; fi
    done
    if have mips64r5900el-ps2-elf-gcc; then c_g "  OK   ee-gcc on PATH"
    else c_r "  MISS ee-gcc not on PATH (run tools/bootstrap.sh, then export what it prints)"; ok=0; fi
    if have Play || [ -x "$HOME/toolchains/squashfs-root/AppRun" ]; then c_g "  OK   Play! emulator found"
    else c_y "  WARN Play! not found (needed for 'run'/'test'; install from playstation2-emulator)"; fi
    echo
    if [ "$ok" = 1 ]; then c_g "Ready. Try: ./forge play spin3d"; else c_r "Not ready. Fix the MISS lines above, then re-run ./forge doctor"; return 1; fi
}

scaffold_makefile(){  # $1 = elf base name -> writes ./Makefile
    cat > Makefile <<MK
# Generated by 'forge new'. Edit EE_BIN to rename your game.
FORGE   = $FORGE_ROOT
EE_BIN  = $1.elf
EE_OBJS = game.o engine.o

EE_INCS    += -I\$(GSKIT)/include -I\$(PS2SDK)/ee/include -I\$(FORGE)/engine
EE_LDFLAGS += -L\$(GSKIT)/lib
EE_LIBS     = -lgskit_toolkit -lgskit -ldmakit -laudsrv -lpad -lm -lc
vpath %.c \$(FORGE)/engine

all: \$(EE_BIN)
run:  \$(EE_BIN) ; Play --elf \$(EE_BIN)
shot: \$(EE_BIN) ; bash \$(FORGE)/tools/shot.sh \$(EE_BIN) 3 shot.png
test: \$(EE_BIN) ; bash \$(FORGE)/tools/shot.sh \$(EE_BIN) 3 shot.png
clean: ; rm -f \$(EE_BIN) \$(EE_OBJS)

include \$(PS2SDK)/samples/Makefile.pref
include \$(PS2SDK)/samples/Makefile.eeglobal
MK
}

new(){
    local name="${1:-}"
    [ -n "$name" ] || { c_r "usage: forge new <name>"; return 1; }
    [ -e "$name" ] && { c_r "'$name' already exists"; return 1; }
    mkdir -p "$name"; cp "$FORGE_ROOT/examples/template/game.c" "$name/game.c"
    ( cd "$name" && scaffold_makefile "$name" )
    c_g "Created ./$name (game.c + Makefile)."
    echo "Next:  cd $name && ../forge build && ../forge run"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
    doctor) doctor ;;
    new)    new "${1:-}" ;;
    build|run|test|shot)
            [ -f Makefile ] || { c_r "no Makefile here. run inside a game folder (see 'forge new'), or 'forge play <example>'"; exit 1; }
            make "$([ "$cmd" = build ] && echo all || echo "$cmd")" ;;
    list)   echo "examples:"; ls "$FORGE_ROOT/examples" ;;
    play)   ex="${1:-}"; [ -d "$FORGE_ROOT/examples/$ex" ] || { c_r "no example '$ex' (try: forge list)"; exit 1; }
            ( cd "$FORGE_ROOT/examples/$ex" && make && make run ) ;;
    gui)    py="${FORGE_PYTHON:-python3}"; port="${FORGE_GUI_PORT:-8090}"
            c_g "dashboard on http://localhost:$port  (Ctrl-C to stop)"
            c_y "remote box? tunnel it first:  ssh -L $port:localhost:$port <host>"
            exec "$py" "$FORGE_ROOT/tools/gui.py" ;;
    help|-h|--help|"") usage ;;
    *) c_r "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
